import streamlit as st
import pickle
import pandas as pd

# Load model
model = pickle.load(open("house_model.pkl", "rb"))
le = pickle.load(open("location_encoder.pkl", "rb"))

st.title("📊 House Price Prediction")

# Inputs
area = st.number_input(
    "Area (sq ft)",
    min_value=500,
    max_value=5000,
    value=1200
)

bedrooms = st.slider(
    "Bedrooms",
    1, 6, 2
)

bathrooms = st.slider(
    "Bathrooms",
    1, 5, 2
)

location = st.selectbox(
    "Location",
    le.classes_
)

# Predict
if st.button("💰 Predict Price"):

    loc_encoded = le.transform([location])[0]

    input_data = pd.DataFrame(
        [[area, bedrooms, bathrooms, loc_encoded]],
        columns=['Area', 'Bedrooms', 'Bathrooms', 'Location']
    )

    prediction = model.predict(input_data)

    st.success(
        f"🏡 Estimated House Price: ₹ {int(prediction[0]):,}"
    )

    st.balloons()
